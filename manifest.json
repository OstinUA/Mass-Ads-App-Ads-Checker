{
  "manifest_version": 3,
  "name": "Mass Ads & App-Ads Checker",
  "version": "2.5.0",
  "description": "Bulk validate ads.txt and app-ads.txt files with deterministic URL probing, IAB line parsing, and CSV export.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Checker",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
